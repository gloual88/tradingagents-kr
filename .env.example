# ===== TradingAgents 환경설정 (.env 로 복사해서 본인 키 입력) =====
# 이 파일(.env.example)은 템플릿입니다. 복사:  cp .env.example .env
# 실제 .env 는 .gitignore 로 제외되어 GitHub에 올라가지 않습니다.

# --- LLM API 키 (Anthropic 사용 권장; 본인 키를 넣으세요) ---
# 키 발급: https://console.anthropic.com  → 실행마다 과금됩니다(본인 부담).
ANTHROPIC_API_KEY=
# (선택, 다른 provider 쓸 때만)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- 모델/동작 (기본값으로 충분) ---
TRADINGAGENTS_LLM_PROVIDER=anthropic
TRADINGAGENTS_DEEP_THINK_LLM=claude-sonnet-4-6
TRADINGAGENTS_QUICK_THINK_LLM=claude-haiku-4-5-20251001
TRADINGAGENTS_OUTPUT_LANGUAGE=Korean
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
# 한국 종목 분석 시 벤치마크(미국이면 비워둠)
TRADINGAGENTS_BENCHMARK_TICKER=^KS11

# --- 대시보드 외부 공개 시 접속 비밀번호(선택) ---
TA_DASH_PASSWORD=
